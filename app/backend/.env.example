# Career Copilot backend — environment variables.
# Copy this file to .env and fill in real values for local development.

# ── In-process background scheduler ──────────────────────────────────
# APScheduler runs the notifications dispatcher + eligibility-recompute
# worker inside the FastAPI process. Default is "false" so dev/test/CI
# boots don't fire the cron loop. Production must set this to "true" on
# exactly ONE backend instance (APScheduler is not distributed).
ENABLE_SCHEDULER=false
